# Token to auth on motherduck
MOTHERDUCK_TOKEN=token_from_motherduck

# Path to the local DuckDB build file, as seen from INSIDE the Astro containers.
# This is the fixed bind-mount root, identical for everyone running `astro dev start`.
# Host-side dbt runs don't need this — profiles.yml falls back to a relative default.
DUCKDB_PATH=/usr/local/airflow/include/transforms/poke_db.duckdb

# SMTP — picked up automatically by Airflow via AIRFLOW__* env var convention
AIRFLOW__SMTP__SMTP_HOST=smtp.office365.com
AIRFLOW__SMTP__SMTP_PORT=587
AIRFLOW__SMTP__SMTP_STARTTLS=True
AIRFLOW__SMTP__SMTP_SSL=False
AIRFLOW__SMTP__SMTP_USER=email_address_to_send_alerts_from
AIRFLOW__SMTP__SMTP_PASSWORD=your_outlook_email_pwd
AIRFLOW__SMTP__SMTP_MAIL_FROM=email_address_to_send_alerts_from

# Airflow Variables — AIRFLOW_VAR_* env vars are resolved automatically by Variable.get()
AIRFLOW_VAR_ALERT_EMAIL=email_address_to_send_alerts_to